# =============================================================================
# Cursor 索引忽略（testA）
# 放置于仓库根目录；Cursor 会自动读取，减少无关文件进入索引与上下文。
# 与 .gitignore 互补：此处可更宽（如大目录），以提升本地 IDE 性能为主。
# =============================================================================

# -----------------------------------------------------------------------------
# Python 构建与缓存
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
develop-eggs/
dist/
downloads/
eggs/
parts/
sdist/
var/
wheels/
*.manifest
*.spec
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# -----------------------------------------------------------------------------
# 虚拟环境
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# 测试 / 覆盖率 / pytest
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Playwright 与 UI 自动化产物（本仓库）
# -----------------------------------------------------------------------------
test-results/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# Allure 与本地报告（与 .gitignore 对齐）
# -----------------------------------------------------------------------------
allure-report/
allure-results/
reports/

# -----------------------------------------------------------------------------
# 诊断与运行时产物（体积大、非源码）
# -----------------------------------------------------------------------------
diagnostic_reports/

# -----------------------------------------------------------------------------
# Cookie 与会话落盘（敏感/可再生成；与 .gitignore 对齐）
# -----------------------------------------------------------------------------
core/cookies*.json
**/cookies*.json
recharge_test_results.json

# -----------------------------------------------------------------------------
# IDE 与系统杂项
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# 环境与密钥（勿进入索引）
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# 日志与临时文件
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# 文档站点生成物
# -----------------------------------------------------------------------------
docs/_build/
site/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# 备份与压缩包（工具脚本产出或手工归档）
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# -----------------------------------------------------------------------------
# 体积较大的测试媒体（仓库内若需索引固定图片素材，可删除本段或收窄路径）
# -----------------------------------------------------------------------------
*.jpg
*.jpeg
*.png
*.gif
*.mp4
*.avi
*.mov
*.webm

# -----------------------------------------------------------------------------
# 本地数据库文件
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
